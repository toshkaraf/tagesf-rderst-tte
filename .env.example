# Copy to ".env" in the same folder (never commit .env).
# Local: Vite dev/preview middleware and "npm run serve:dist" read this file.
# Vercel: set GEMINI_API_KEY in Project → Settings → Environment Variables (Production + Preview).
# Never use VITE_* for secrets — those are embedded in the browser bundle.

GEMINI_API_KEY=

# Optional: Gemini model id (default: gemini-2.5-flash). Alternatives: gemini-3.5-flash, gemini-3.1-flash-lite
# GEMINI_MODEL=gemini-2.5-flash

# Optional: persistent quiz cooldown history (single-user site).
# Create table with scripts/supabase-quiz-history.sql, then set:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
